# AWS Bedrock credentials (for LLM rule generation)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=your_aws_session_token
AWS_DEFAULT_REGION=us-east-1

# Spring Cloud Config Server — remote Git repo containing alerting-service.yml
# The repo must contain the file alerting-service.yml (see alerting-config/ directory)
CONFIG_GIT_URI=https://github.com/your-org/alerting-config
CONFIG_GIT_TOKEN=your_git_personal_access_token
